<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error - Evaluación de Desempeño</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root { --primary: #1e3a5f; }
    body { font-family: 'Segoe UI', sans-serif; background: #f8f9fa; min-height: 100vh; display: flex; flex-direction: column; }
    .error-container { flex: 1; display: flex; align-items: center; justify-content: center; padding: 40px; }
    .footer-custom { background: var(--primary); color: white; padding: 30px 0; }
    .footer-custom a { color: #3498db; text-decoration: none; }
  </style>
</head>
<body>
  <div class="error-container">
    <div class="card shadow" style="max-width: 500px; text-align: center;">
      <div class="card-body p-5">
        <i class="fas fa-exclamation-triangle text-warning fa-4x mb-4"></i>
        <h2 class="card-title"><%= error?.message || 'Error' %></h2>
        <p class="text-muted">Ha ocurrido un error inesperado.</p>
        <a href="/" class="btn btn-primary"><i class="fas fa-home me-1"></i>Volver al Inicio</a>
      </div>
    </div>
  </div>
  <footer class="footer-custom">
    <div class="container">
      <div class="row"><div class="col-12 text-center">
        <h5 class="mb-3">👨‍💻 Desarrollado por Isaac Esteban Haro Torres</h5>
        <p class="mb-2"><strong>Ingeniero en Sistemas</strong> · <strong>Full Stack</strong> · <strong>Automatización</strong> · <strong>Data</strong></p>
        <div class="d-flex justify-content-center flex-wrap gap-3">
          <a href="mailto:zackharo1@gmail.com"><i class="fas fa-envelope me-1"></i>Email: zackharo1@gmail.com</a>
          <a href="https://wa.me/59398805517" target="_blank"><i class="fab fa-whatsapp me-1"></i>WhatsApp: 098805517</a>
          <a href="https://github.com/ieharo1" target="_blank"><i class="fab fa-github me-1"></i>GitHub</a>
          <a href="https://ieharo1.github.io/portafolio-isaac.haro/" target="_blank"><i class="fas fa-globe me-1"></i>Portafolio</a>
        </div>
        <hr class="my-3" style="border-color: rgba(255,255,255,0.3);">
        <p class="mb-0 text-white-50"><small>© <%= new Date().getFullYear() %> Sistema de Evaluación</small></p>
      </div></div>
    </div>
  </footer>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
